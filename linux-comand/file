# Сделать файл неизменяемым
sudo chattr +i /etc/resolv.conf

# Разрешить изменения
sudo chattr -i /etc/resolv.conf

#  Binwalk — это инструмент для поиска и извлечения файлов и данных, которые спрятаны внутри других файлов
binwalk -e test.png

# strings — это утилита, которая извлекает и отображает последовательности печатных символов из двоичных файлов. Она полезна для поиска текстовой информации, такой как пароли, URL-адреса или другие строки, которые могут быть скрыты внутри исполняемых файлов, библиотек или других бинарных данных.
strings test.png

# ExifTool — это мощная утилита для чтения, записи и редактирования метаданных в различных типах файлов, включая изображения, аудио и видео. Она может извлекать информацию о камере, дате создания, геолокации и других метаданных, которые могут быть полезны для анализа или получения дополнительной информации о файле.
exiftool test.png

# Hexeditor для редактирования файлов в hex
hexeditor reverse.php.png