# CSP — это механизм безопасности, который сообщает браузеру, откуда разрешено загружать ресурсы (скрипты, стили, изображения и т.д.). Защищает от XSS, data injection и других атак.


┌─────────────────────────────────────────────────────────────────────────────┐
│                         CSP (Content Security Policy)                       │
├─────────────────────────────────────────────────────────────────────────────┤
│  Content-Security-Policy: directive1 value1; directive2 value2             │
├─────────────────────────────────────────────────────────────────────────────┤
│                                                                             │
│  ДИРЕКТИВЫ                          ЗНАЧЕНИЯ                                │
│  ─────────                           ────────                               │
│  default-src   → источник по умолч   'self'       → свой домен              │
│  script-src    → скрипты             'none'       → ничего                  │
│  style-src     → стили               'unsafe-inline' → inline (опасно!)     │
│  img-src       → картинки            'unsafe-eval'   → eval() (опасно!)     │
│  connect-src   → fetch/XHR           'strict-dynamic' → доверять цепочке    │
│  font-src      → шрифты              https://cdn.com → конкретный домен     │
│  frame-src     → iframe              *            → любой (опасно)          │
│  object-src    → плагины             data:        → data: URI               │
│  base-uri      → <base> тег          http://*.site.com → любой поддомен     │
│  form-action   → отправка форм       'nonce-abc123' → одноразовый токен     │
│  frame-ancestors → встраивание       'sha256-abc' → хеш inline кода         │
│                                                                             │
├─────────────────────────────────────────────────────────────────────────────┤
│  ПРИМЕРЫ                                                                   │
│                                                                             │
│  # Минимальная безопасная                                                   │
│  default-src 'self'; object-src 'none'                                      │
│                                                                             │
│  # С внешними ресурсами                                                     │
│  default-src 'self'; script-src 'self' https://cdn.com; style-src 'self'    │
│                                                                             │
│  # Разрешить inline-стили, запретить inline-скрипты                         │
│  script-src 'self'; style-src 'self' 'unsafe-inline'                        │
│                                                                             │
│  # С nonce (безопасные inline-скрипты)                                      │
│  script-src 'nonce-r4nd0m' 'strict-dynamic'                                 │
│  <script nonce="r4nd0m">alert(1)</script>                                   │
│                                                                             │
│  # С report-uri (логирование нарушений)                                     │
│  default-src 'self'; report-uri /csp-violation                              │
│                                                                             │
│  # Защита от clickjacking (вместо X-Frame-Options)                          │
│  frame-ancestors 'self' https://trusted.com                                 │
│                                                                             │
├─────────────────────────────────────────────────────────────────────────────┤
│  ЧТО НЕЛЬЗЯ ДЕЛАТЬ                      ПОЧЕМУ                              │
│  ────────────────                       ─────                               │
│  script-src 'unsafe-inline'             XSS через inline-код                │
│  script-src 'unsafe-eval'               eval() обходит политику             │
│  default-src *                          любой сайт может загрузить ресурсы  │
│  object-src 'self'                      Flash/Java могут быть векторами     │
│                                                                             │
└─────────────────────────────────────────────────────────────────────────────┘