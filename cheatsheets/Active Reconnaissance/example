# traceroute - показывает путь до указанного хоста

# telnet - используется для подключения к удаленным хостам по протоколу Telnet(
	можно проверить доступность порта на удаленном хосте
):
telnet HOST <порт>

# netcat - используется для подключения к удаленным хостам по протоколу TCP/IP можно проверить доступность порта на удаленном хосте:

nc -lnvp <порт>  # слушать указанный порт
nc <хост> <порт> # подключиться к указанному хосту и пор